##########################
# Repository-wide ignores
##########################
# Backend build artifacts
/server/target/
/server/*.log
/server/*.pid
/server/*.err
/server/*.out
/logs/

# All server versioned log files (server-v3.log through server-v99.log)
server/server-v*.log
server/server-v*.err
server/server-v*.out
server/server-current*.log
server/server-current*.err
server/server-new*.log
server/server-new*.err
server/server-local*.log
server/server-local*.err
server/server-debug.log
server/server-test.log
server/server-error.log
server/server-startup.log
server/startup.log
server/app.log
server/..server-output.log

# Root-level log/err files generated by local server runs
server-run.log
server-run.err
server-output.log
server-start.log
web-admin-run.log
web-admin-start.log
web-admin-output.log
web-admin-run.err

# Android APK build outputs
/Android/apk-output/
/artifacts/android/*.apk

# Backend IDE metadata (Eclipse)
/server/.settings/
/server/.classpath
/server/.factorypath
/server/.project

# Java class files (just in case another directory sneaks them in)
*.class

# Android local/generated files
/Android/*.log
/Android/local.properties
/Android/.gradle/
/Android/.kotlin/
/Android/build/

# Editor temp files
*.swp
*.swo
*~

# Node.js
node_modules/
/web-admin/dist/
package-lock.json
package.json
server/.env*
!server/.env.example
.env
!.env.example

# Android secrets (use secrets.properties.example as template)
Android/secrets.properties
Android/local.properties

# Android app build outputs
Android/app/build/
Android/app/*.apk
Android/app/*.aab

# Local Maven distribution (not needed in VCS)
/maven/
/maven.zip

# Test files
test.html

# Python scripts (one-time utilities)
*.py

# Local dev CDN uploads (not for VCS)
/cdn/

# Generated analysis and scratch output
/graphify-out/
/scratch/

# Duplicate static export folder; active web assets live in web-admin/public/
/website/

# Claude Code local session data
.claude/

# macOS
.DS_Store
**/.DS_Store

# Windows
Thumbs.db

# Android Studio root-project metadata generated when the repo root is opened
*.iml
/.idea/.gitignore
/.idea/AndroidProjectSystem.xml
/.idea/Kbook.iml
/.idea/caches/
/.idea/deploymentTargetSelector.xml
/.idea/markdown.xml
/.idea/misc.xml
/.idea/modules.xml
/.idea/runConfigurations.xml
/.idea/vcs.xml
/.idea/workspace.xml
nul
Android/nul

# Antigravity agents & local builds
.agents/
Android/*.apk

