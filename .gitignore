##########################
# Repository-wide ignores
##########################
# Backend build artifacts
/server/target/
/server/*.log
/server/*.pid

# Backend IDE metadata (Eclipse)
/server/.settings/
/server/.classpath
/server/.factorypath
/server/.project

# Java class files (just in case another directory sneaks them in)
*.class

# Android local/generated files
/Android/*.log
/Android/local.properties
/Android/.gradle/
/Android/.kotlin/
/Android/build/

# Editor temp files
*.swp
*.swo
*~

# Node.js
node_modules/
package-lock.json
package.json
server/.env.production

# Android secrets (use secrets.properties.example as template)
Android/secrets.properties
Android/local.properties

# Android app build outputs
Android/app/build/
Android/app/*.apk
Android/app/*.aab

# Python scripts (one-time utilities)
*.py

# Claude Code local session data
.claude/

# macOS
.DS_Store
**/.DS_Store

# Windows
Thumbs.db
