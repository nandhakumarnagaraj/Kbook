# Copy this file to /var/www/kbook.iadv.cloud/.env before first production deploy.
# Do not commit real secrets.

# Docker Compose production database
POSTGRES_DB=kbook_saas
POSTGRES_USER=kbookuser
POSTGRES_PASSWORD=CHANGE_ME

# Host/service deployment database settings.
# Use these only if the server is started directly by systemd instead of Docker Compose.
DB_URL=jdbc:postgresql://127.0.0.1:5432/kbook_saas
DB_USERNAME=kbookuser
DB_PASSWORD=CHANGE_ME
SPRING_PROFILES_ACTIVE=prod

# Server
SERVER_PORT=8081
SERVER_FORWARD_HEADERS_STRATEGY=framework

# JWT
JWT_SECRET=CHANGE_ME

# Google OAuth
GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com

# WhatsApp / Meta Cloud API
WHATSAPP_META_ACCESS_TOKEN=CHANGE_ME
WHATSAPP_META_PHONE_NUMBER_ID=CHANGE_ME
WHATSAPP_META_OTP_TEMPLATE_NAME=CHANGE_ME

# Payments
APP_BASE_URL=https://your-api-domain.com
PAYMENT_CRYPTO_SECRET=CHANGE_ME_CHANGE_ME_CHANGE_ME_32_BYTES_MIN

# CDN asset storage on VPS
CDN_BASE_PATH=/var/www/cdn.kbook.iadv.cloud/restaurants/
CDN_URL_PREFIX=https://kbook.iadv.cloud/cdn/
CDN_TMP_PATH=/var/www/cdn.kbook.iadv.cloud/tmp/
CWEBP_BIN=cwebp

# Email (SMTP) — used for refund confirmations, settlement notifications, chargeback alerts
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME@gmail.com
MAIL_PASSWORD=CHANGE_ME
EMAIL_ENABLED=false

# Optional Spring settings
SPRINGDOC_API_DOCS_ENABLED=false
SPRINGDOC_SWAGGER_UI_ENABLED=false
CORS_ALLOWED_ORIGINS=https://kbook.iadv.cloud
