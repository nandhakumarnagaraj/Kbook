<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.KhanaBookLite" parent="android:Theme.Material.NoActionBar">
        <!-- Prevent the Android 15+ "elegant text height" change from inflating line heights
             for multilingual scripts (Devanagari, Arabic, etc.) which makes text appear bigger. -->
        <item name="android:elegantTextHeight">false</item>
        <item name="android:windowBackground">@drawable/launch_screen_background</item>
    </style>

    <style name="Theme.KhanaBookLite.Launch" parent="Theme.KhanaBookLite">
        <item name="android:windowBackground">@drawable/launch_screen_background</item>
    </style>

</resources>
