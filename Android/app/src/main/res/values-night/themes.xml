<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
    ═══════════════════════════════════════════════════════════════
    KHANBOOK DARK THEME
    "Midnight Harvest" — near-pitch-black surfaces, saffron brand
    ═══════════════════════════════════════════════════════════════
    -->
    <style name="Theme.KhanaBookLite" parent="Theme.MaterialComponents.DayNight.NoActionBar">

        <!-- Preserve Indic script rendering for restaurant names -->
        <item name="android:elegantTextHeight">true</item>
        <item name="android:windowBackground">@drawable/launch_screen_background</item>

        <!-- ── Background tokens ──────────────────────────────── -->
        <item name="colorBgPrimary">@color/kb_dark_bg</item>
        <item name="colorBgSecondary">@color/kb_dark_surface</item>
        <item name="colorBgCard">@color/kb_dark_surface</item>
        <item name="colorBgDisabled">@color/kb_white_alpha_05</item>
        <item name="colorBgMainSubtle">@color/kb_saffron_950</item>
        <item name="colorBgOverlay">@color/kb_white_alpha_30</item>

        <!-- ── Brand / Primary tokens ─────────────────────────── -->
        <item name="colorMainPrimary">@color/kb_brand_saffron_light</item>
        <item name="colorMainPrimaryBold">@color/kb_brand_saffron</item>
        <item name="colorMainPrimarySubtle">@color/kb_saffron_950</item>

        <!-- ── Text tokens ────────────────────────────────────── -->
        <item name="colorTextPrimary">@color/kb_white_alpha_90</item>
        <item name="colorTextSecondary">@color/kb_white_alpha_70</item>
        <item name="colorTextTertiary">@color/kb_white_alpha_50</item>
        <item name="colorTextOnBrand">@color/kb_white</item>
        <item name="colorTextDisabled">@color/kb_white_alpha_30</item>
        <item name="colorTextPositive">@color/kb_green</item>
        <item name="colorTextNegative">@color/kb_red</item>
        <item name="colorTextWarning">@color/kb_yellow</item>
        <item name="colorTextInfo">@color/kb_blue</item>

        <!-- ── Outline / Border tokens ───────────────────────── -->
        <item name="colorOutlineSubtle">@color/kb_white_alpha_05</item>
        <item name="colorOutlineBold">@color/kb_white_alpha_10</item>
        <item name="colorOutlineMain">@color/kb_brand_saffron_light</item>

        <!-- ── Status background tokens ──────────────────────── -->
        <item name="colorBgPositive">@color/kb_green</item>
        <item name="colorBgPositiveSubtle">@color/kb_green_dark</item>
        <item name="colorBgNegative">@color/kb_red</item>
        <item name="colorBgNegativeSubtle">@color/kb_red_dark</item>
        <item name="colorBgWarning">@color/kb_yellow</item>
        <item name="colorBgWarningSubtle">@color/kb_yellow_dark</item>
        <item name="colorBgInfo">@color/kb_blue</item>
        <item name="colorBgInfoSubtle">@color/kb_blue_dark</item>

        <!-- ── Navigation bar tokens ─────────────────────────── -->
        <item name="colorNavBgSelected">@color/kb_saffron_950</item>
        <item name="colorNavBgUnselected">@color/kb_dark_surface</item>
        <item name="colorNavIconSelected">@color/kb_brand_saffron_light</item>
        <item name="colorNavIconUnselected">@color/kb_white_alpha_30</item>

        <!-- ── Material color system mapping ─────────────────── -->
        <item name="colorPrimary">@color/kb_brand_saffron_light</item>
        <item name="colorPrimaryVariant">@color/kb_brand_saffron</item>
        <item name="colorOnPrimary">@color/kb_white</item>
        <item name="colorSecondary">@color/kb_gray_700</item>
        <item name="colorOnSecondary">@color/kb_white</item>
        <item name="colorSurface">@color/kb_dark_surface</item>
        <item name="colorOnSurface">@color/kb_white_alpha_90</item>
        <item name="android:colorBackground">@color/kb_dark_bg</item>

        <!-- ── Shape / size tokens ────────────────────────────── -->
        <item name="btnHeightLarge">48dp</item>
        <item name="btnHeightMedium">44dp</item>
        <item name="btnHeightSmall">32dp</item>
        <item name="btnCornerRadius">10dp</item>
        <item name="cardCornerRadius">14dp</item>
        <item name="chipCornerRadius">8dp</item>
        <item name="inputCornerRadius">10dp</item>
        <item name="dialogCornerRadius">18dp</item>
        <item name="bottomSheetCornerRadius">18dp</item>

    </style>

    <!-- Launch / Splash theme (pre-Compose, dark) -->
    <style name="Theme.KhanaBookLite.Launch" parent="Theme.KhanaBookLite">
        <item name="android:windowBackground">@drawable/launch_screen_background</item>
        <item name="android:windowSplashScreenBackground">@color/splash_bg</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="android:windowSplashScreenIconBackgroundColor">#FFFFFF</item>
    </style>

</resources>
