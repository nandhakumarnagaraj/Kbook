<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ═══════════════════════════════════════════════
         KHANBOOK DARK THEME
         Near-black + teal brand
    ════════════════════════════════════════════════ -->
    <style name="Theme.KhanaBookLite" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:elegantTextHeight">false</item>
        <item name="android:windowBackground">@drawable/launch_screen_background</item>

        <!-- Background tokens -->
        <item name="colorBgPrimary">@color/kb_gray_950</item>
        <item name="colorBgSecondary">@color/kb_gray_900</item>
        <item name="colorBgCard">@color/kb_gray_900</item>
        <item name="colorBgDisabled">@color/kb_white_alpha_05</item>
        <item name="colorBgMainSubtle">@color/kb_teal_950</item>
        <item name="colorBgOverlay">@color/kb_white_alpha_30</item>

        <!-- Brand / Primary tokens -->
        <item name="colorMainPrimary">@color/kb_teal_400</item>
        <item name="colorMainPrimaryBold">@color/kb_teal_500</item>
        <item name="colorMainPrimarySubtle">@color/kb_teal_950</item>

        <!-- Text tokens -->
        <item name="colorTextPrimary">@color/kb_white_alpha_90</item>
        <item name="colorTextSecondary">@color/kb_white_alpha_70</item>
        <item name="colorTextTertiary">@color/kb_white_alpha_50</item>
        <item name="colorTextOnBrand">@color/kb_white</item>
        <item name="colorTextDisabled">@color/kb_white_alpha_30</item>
        <item name="colorTextPositive">@color/kb_green_500</item>
        <item name="colorTextNegative">@color/kb_red_400</item>
        <item name="colorTextWarning">@color/kb_yellow_500</item>
        <item name="colorTextInfo">@color/kb_blue_500</item>

        <!-- Outline / Border tokens -->
        <item name="colorOutlineSubtle">@color/kb_white_alpha_05</item>
        <item name="colorOutlineBold">@color/kb_white_alpha_10</item>
        <item name="colorOutlineMain">@color/kb_teal_400</item>

        <!-- Status bg tokens -->
        <item name="colorBgPositive">@color/kb_green_500</item>
        <item name="colorBgPositiveSubtle">@color/kb_green_950</item>
        <item name="colorBgNegative">@color/kb_red_400</item>
        <item name="colorBgNegativeSubtle">@color/kb_red_950</item>
        <item name="colorBgWarning">@color/kb_yellow_500</item>
        <item name="colorBgWarningSubtle">@color/kb_yellow_950</item>
        <item name="colorBgInfo">@color/kb_blue_500</item>
        <item name="colorBgInfoSubtle">@color/kb_blue_950</item>

        <!-- Navigation bar tokens -->
        <item name="colorNavBgSelected">@color/kb_teal_950</item>
        <item name="colorNavBgUnselected">@color/kb_gray_800</item>
        <item name="colorNavIconSelected">@color/kb_teal_400</item>
        <item name="colorNavIconUnselected">@color/kb_white_alpha_30</item>

        <!-- Material color system mapping -->
        <item name="colorPrimary">@color/kb_teal_400</item>
        <item name="colorPrimaryVariant">@color/kb_teal_500</item>
        <item name="colorOnPrimary">@color/kb_white</item>
        <item name="colorSecondary">@color/kb_gray_700</item>
        <item name="colorOnSecondary">@color/kb_white</item>
        <item name="colorSurface">@color/kb_gray_900</item>
        <item name="colorOnSurface">@color/kb_white_alpha_90</item>
        <item name="android:colorBackground">@color/kb_gray_950</item>

        <!-- Button / Shape sizes -->
        <item name="btnHeightLarge">56dp</item>
        <item name="btnHeightMedium">44dp</item>
        <item name="btnHeightSmall">32dp</item>
        <item name="btnCornerRadius">12dp</item>
        <item name="cardCornerRadius">14dp</item>
        <item name="chipCornerRadius">8dp</item>
    </style>

    <style name="Theme.KhanaBookLite.Launch" parent="Theme.KhanaBookLite">
        <item name="android:windowBackground">@drawable/launch_screen_background</item>
        <item name="android:windowSplashScreenBackground">@color/splash_bg</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/khanabook_logo</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@android:color/transparent</item>
    </style>

</resources>
