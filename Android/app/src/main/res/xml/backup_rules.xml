<?xml version="1.0" encoding="utf-8"?>
<!--
    Android Auto Backup rules (API < 31).
    Used when android:fullBackupContent points here.

    Policy: exclude all local databases and shared preferences.
    Billing data, session tokens, and PIN hashes must never leave the
    device via cloud backup — they are either re-synced from the server
    on next login or re-entered by the user.
-->
<full-backup-content>

    <!-- Local Room databases — contain billing, menu, and session data -->
    <exclude domain="database" path="." />

    <!-- SharedPreferences — contain auth tokens, PIN hash, app settings -->
    <exclude domain="sharedpref" path="." />

    <!-- Internal files — contain cached invoices and logo assets -->
    <exclude domain="file" path="invoices/" />
    <exclude domain="file" path="images/" />

    <!-- External cache — not sensitive but no value in backing up -->
    <exclude domain="external" path="." />

</full-backup-content>
