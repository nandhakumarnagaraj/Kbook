<?xml version="1.0" encoding="utf-8"?>
<!--
    KhanaBook launch / splash screen background.
    Clean white background for launcher.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base layer: dark purple -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0E0A22" />
        </shape>
    </item>

    <!-- Logo glow layer: centered -->
    <item
        android:width="160dp"
        android:height="160dp"
        android:gravity="center"
        android:drawable="@drawable/splash_logo_with_glow" />

</layer-list>
