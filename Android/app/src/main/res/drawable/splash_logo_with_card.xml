<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- White rounded card background (matching the 120dp Compose card with 24dp corners) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
            <corners android:radius="24dp" />
        </shape>
    </item>
    
    <!-- Logo centered inside the card with padding -->
    <item
        android:top="20dp"
        android:bottom="20dp"
        android:left="20dp"
        android:right="20dp">
        <bitmap
            android:src="@drawable/ic_khanabook_logo"
            android:gravity="center" />
    </item>
</layer-list>
