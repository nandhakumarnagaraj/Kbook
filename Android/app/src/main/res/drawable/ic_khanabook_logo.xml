<?xml version="1.0" encoding="utf-8"?>
<!--
    KhanaBook in-app logo mark.
    48×48dp — used in HomeScreen header, SplashScreen, LoginScreen.

    Design: open book with spine + two pages, saffron plate arc + dot
    above. White strokes on transparent — works on both dark and light
    backgrounds (the caller wraps it in a coloured container).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="48dp"
    android:height="48dp"
    android:viewportWidth="48"
    android:viewportHeight="48">

    <!-- ── Left page fill ──────────────────────────────────────── -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.18"
        android:pathData="M24,14 L29,19 L29,38 L24,33 Z" />

    <!-- ── Right page fill ─────────────────────────────────────── -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.25"
        android:pathData="M24,14 L19,19 L19,38 L24,33 Z" />

    <!-- ── Left page stroke ────────────────────────────────────── -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.6"
        android:fillColor="@android:color/transparent"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M24,14 L29,19 L29,38 L24,33" />

    <!-- ── Right page stroke ───────────────────────────────────── -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.6"
        android:fillColor="@android:color/transparent"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M24,14 L19,19 L19,38 L24,33" />

    <!-- ── Spine ───────────────────────────────────────────────── -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.6"
        android:fillColor="@android:color/transparent"
        android:strokeLineCap="round"
        android:pathData="M24,14 L24,33" />

    <!-- ── Bottom connector ────────────────────────────────────── -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.4"
        android:fillColor="@android:color/transparent"
        android:strokeLineCap="round"
        android:pathData="M19,38 Q24,41 29,38" />

    <!-- ── Saffron plate arc ────────────────────────────────────── -->
    <path
        android:strokeColor="#D97706"
        android:strokeWidth="1.6"
        android:fillColor="@android:color/transparent"
        android:strokeLineCap="round"
        android:pathData="M19,13 Q24,8 29,13" />

    <!-- ── Saffron plate dot ────────────────────────────────────── -->
    <path
        android:fillColor="#D97706"
        android:pathData="M24,12 m-3,0 a3,3 0,1 1,6 0 a3,3 0,1 1,-6 0" />

    <!-- ── Left page ruled lines ───────────────────────────────── -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="0.9"
        android:fillColor="@android:color/transparent"
        android:strokeLineCap="round"
        android:strokeAlpha="0.40"
        android:pathData="M25.5,23 L28,23 M25.5,27 L28,27 M25.5,31 L28,31" />

    <!-- ── Right page ruled lines ──────────────────────────────── -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="0.9"
        android:fillColor="@android:color/transparent"
        android:strokeLineCap="round"
        android:strokeAlpha="0.40"
        android:pathData="M20,23 L22.5,23 M20,27 L22.5,27 M20,31 L22.5,31" />

</vector>
