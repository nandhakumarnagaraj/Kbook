<?xml version="1.0" encoding="utf-8"?>
<!--
    KhanaBook adaptive icon background.
    Warm saffron radial gradient — matches the brand "Grounded Earth & Saffron"
    palette. The safe zone for adaptive icons is the inner 66×66dp of the
    108×108dp canvas, so the gradient is centred there.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Base saffron fill -->
    <path
        android:fillColor="#D97706"
        android:pathData="M0,0h108v108h-108z" />

    <!-- Radial highlight — lighter centre, darker edges -->
    <path
        android:fillColor="#E8832A"
        android:fillAlpha="0.55"
        android:pathData="M54,54 m-38,0 a38,38 0,1 1,76 0 a38,38 0,1 1,-76 0" />

    <!-- Subtle dark vignette at corners for depth -->
    <path
        android:fillColor="#7A3300"
        android:fillAlpha="0.22"
        android:pathData="M0,0 L30,0 Q0,0 0,30 Z" />
    <path
        android:fillColor="#7A3300"
        android:fillAlpha="0.22"
        android:pathData="M108,0 L78,0 Q108,0 108,30 Z" />
    <path
        android:fillColor="#7A3300"
        android:fillAlpha="0.22"
        android:pathData="M0,108 L30,108 Q0,108 0,78 Z" />
    <path
        android:fillColor="#7A3300"
        android:fillAlpha="0.22"
        android:pathData="M108,108 L78,108 Q108,108 108,78 Z" />

</vector>
