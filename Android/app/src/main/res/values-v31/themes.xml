<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
    Android 12+ (API 31+) splash screen.
    Uses the SplashScreen API attributes — these override the base theme
    for the launch activity only.
    -->
    <style name="Theme.KhanaBookLite.Launch" parent="Theme.KhanaBookLite">
        <item name="android:windowBackground">@drawable/launch_screen_background</item>

        <!-- Splash screen background — matches launch_screen_background gradient start -->
        <item name="android:windowSplashScreenBackground">@color/splash_bg</item>

        <!-- Foreground icon — use the vector foreground, not the PNG -->
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>

        <!-- Icon background circle — saffron brand colour -->
        <item name="android:windowSplashScreenIconBackgroundColor">@color/kb_brand_saffron_android</item>

        <!-- Branding image shown below the icon (optional — remove if not needed) -->
        <!-- <item name="android:windowSplashScreenBrandingImage">@drawable/ic_khanabook_logo</item> -->

    </style>

</resources>
