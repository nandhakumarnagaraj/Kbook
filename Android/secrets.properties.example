# ── Android Release Signing Template ──────────────────────────────────────────
# 1. Copy relevant contents into 'local.properties' in the root project folder.
# 2. Replace the values below with your actual credentials.
# 3. ⚠️  NEVER commit real credentials to version control.

# Generate a keystore with: keytool -genkey -v -keystore release-key.jks
#   -alias <alias> -keyalg RSA -keysize 2048 -validity 10000
SIGNING_STORE_FILE=release-key.jks
SIGNING_STORE_PASSWORD=YOUR_KEYSTORE_PASSWORD
SIGNING_KEY_ALIAS=YOUR_KEY_ALIAS
SIGNING_KEY_PASSWORD=YOUR_KEY_PASSWORD

# Default backend URL
BACKEND_URL=https://kbook.iadv.cloud/

# Google OAuth 2.0 Client ID (Web Application type)
# Found in Google Cloud Console or google-services.json
GOOGLE_WEB_CLIENT_ID=836086274000-csivf8msgpphl69hn6ftqdeb1mjceaak.apps.googleusercontent.com
