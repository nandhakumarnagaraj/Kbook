# Copy this file to .env and fill in all values.
# NEVER commit .env to version control.

# Database
POSTGRES_DB=kbook_saas
POSTGRES_USER=kbookuser
POSTGRES_PASSWORD=CHANGE_ME

# Server
SERVER_PORT=8081

# JWT — generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME

# Google OAuth
GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com

# WhatsApp / Meta Cloud API
WHATSAPP_META_ACCESS_TOKEN=CHANGE_ME
WHATSAPP_META_PHONE_NUMBER_ID=CHANGE_ME
WHATSAPP_META_OTP_TEMPLATE_NAME=CHANGE_ME

# Payments
APP_BASE_URL=https://your-api-domain.com
PAYMENT_CRYPTO_SECRET=CHANGE_ME_CHANGE_ME_CHANGE_ME_32_BYTES_MIN

# CDN asset storage on VPS
CDN_BASE_PATH=/var/www/cdn.kbook.iadv.cloud/restaurants/
CDN_URL_PREFIX=https://cdn.kbook.iadv.cloud/restaurants/
CDN_TMP_PATH=/var/www/cdn.kbook.iadv.cloud/tmp/
CWEBP_BIN=cwebp
# Stitch Design API Key — for DESIGN.md validation via Google Stitch MCP
STITCH_API_KEY=CHANGE_ME

# Email (SMTP) — used for refund confirmations, settlement notifications, chargeback alerts
# Defaults: host=smtp.gmail.com, port=587, enabled=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME@gmail.com
MAIL_PASSWORD=CHANGE_ME
EMAIL_ENABLED=false


# Optional Spring settings
SPRINGDOC_API_DOCS_ENABLED=true
SPRINGDOC_SWAGGER_UI_ENABLED=true
SERVER_FORWARD_HEADERS_STRATEGY=framework

# CORS — comma-separated allowed origins for browser clients
CORS_ALLOWED_ORIGINS=https://kbook.iadv.cloud,http://localhost:4200

# Easebuzz Payment Gateway (sub-merchant fund splitting)
# Sandbox: https://testpay.easebuzz.in / https://testdashboard.easebuzz.in
# Production: https://pay.easebuzz.in / https://dashboard.easebuzz.in
EASEBUZZ_MERCHANT_KEY=CHANGE_ME
EASEBUZZ_SALT=CHANGE_ME
EASEBUZZ_PAYMENT_BASE_URL=https://testpay.easebuzz.in
EASEBUZZ_DASHBOARD_BASE_URL=https://testdashboard.easebuzz.in
# Webhook/return URLs — set to your dev tunnel or production domain
EASEBUZZ_RETURN_URL=http://localhost:8081/api/v2/payments/easebuzz/return
EASEBUZZ_NOTIFY_URL=http://localhost:8081/api/v2/payments/easebuzz/webhook
EASEBUZZ_WEBHOOK_URL=http://localhost:8081/api/v2/payments/easebuzz/webhook

# Easebuzz WIRE Platform (sub-merchant mgmt, KYC, lookups)
# WIRE base URL -- default is https://wire.easebuzz.in (production)
# Sandbox URL: https://testdashboard.easebuzz.in
# EASEBUZZ_WIRE_BASE_URL=https://wire.easebuzz.in
# WIRE API Key -- provided by Easebuzz for sub-merchant management APIs
EASEBUZZ_WIRE_API_KEY=CHANGE_ME
