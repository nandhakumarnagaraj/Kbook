# Copy this file to .env and fill in all values.
# NEVER commit .env to version control.

# Database
DB_NAME=khanabook
DB_USERNAME=khanabook_user
DB_PASSWORD=CHANGE_ME

# Server
SERVER_PORT=8081

# JWT — generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME

# Google OAuth
GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com

# WhatsApp / Meta Cloud API
WHATSAPP_META_ACCESS_TOKEN=CHANGE_ME
WHATSAPP_META_PHONE_NUMBER_ID=CHANGE_ME
WHATSAPP_META_OTP_TEMPLATE_NAME=CHANGE_ME

# CORS — comma-separated allowed origins for browser clients (leave blank to allow all)
CORS_ALLOWED_ORIGINS=
